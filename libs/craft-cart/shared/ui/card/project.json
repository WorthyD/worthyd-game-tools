{
  "name": "card",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/craft-cart/shared/ui/card/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": ["type:ui"],
  "targets": {
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/craft-cart/shared/ui/card/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "component-test": {
      "executor": "@nx/cypress:cypress",
      "options": {
        "cypressConfig": "libs/craft-cart/shared/ui/card/cypress.config.ts",
        "testingType": "component",
        "skipServe": true,
        "devServerTarget": "craft-cart:build"
      }
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "libs/craft-cart/shared/ui/card/.storybook",
        "browserTarget": "card:build-storybook",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/card",
        "configDir": "libs/craft-cart/shared/ui/card/.storybook",
        "browserTarget": "card:build-storybook",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "test-storybook -c libs/craft-cart/shared/ui/card/.storybook --url=http://localhost:4400"
      }
    },
    "static-storybook": {
      "executor": "@nx/web:file-server",
      "dependsOn": ["build-storybook"],
      "options": {
        "buildTarget": "card:build-storybook",
        "staticFilePath": "dist/storybook/card",
        "spa": true
      },
      "configurations": {
        "ci": {
          "buildTarget": "card:build-storybook:ci"
        }
      }
    }
  }
}
