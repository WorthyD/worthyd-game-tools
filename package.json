{
  "name": "worthyd-game-tools",
  "version": "1.3.0",
  "scripts": {
    "start": "nx run destiny-clan-dashboard:serve -- --port=4321",
    "build": "nx run destiny-clan-dashboard:build",
    "test": "nx run-many --all --target=test --maxWorkers=1",
    "test:cov": "nx run-many --all --target=test --coverage --maxWorkers=1",
    "watch": "ng build --watch --configuration development",
    "build:stats": "ng build --project=clan-dashboard --configuration production --stats-json",
    "analyze": "npx webpack-bundle-analyzer dist/clan-dashboard/stats.json",
    "___test": "ng test --watch false --browsers=ChromeHeadless",
    "____test:ui": "ng test --project=clan-dashboard",
    "_____test:data": "jest --config ./projects/data/jest.config.js",
    "____test:data:headless": "ng test --project=data --browsers=ChromeHeadless ",
    "____test:data:coverage": "ng test --project=data --code-coverage=true",
    "____test:components": "ng test --project=components",
    "____test:components:coverage": "ng test --project=components --browsers=ChromeHeadless --code-coverage=true --watch=false",
    "____storybook": "ng run clan-dashboard:storybook",
    "config": "ts-node set-env.ts",
    "____lint": "ng lint",
    "_____test:ui": "jest --config ./projects/clan-dashboard/jest.config.js"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "19.2.10",
    "@angular/cdk": "19.2.16",
    "@angular/common": "19.2.10",
